@model ProjectListModel
@{
    Layout = "~/Administration/Views/Shared/_AdminLayout.cshtml";
    //page title
    ViewBag.Title = T("Admin.Dashboard").Text;
    var gridPageSize = 5;
}

@Html.AntiForgeryToken()

<div class="content-header clearfix">
    <h1 class="pull-left">
        Projects details
    </h1>
    @Html.Partial("_SimGateHeader", Model)
</div>
<div class="content">
    <div class="row">
        <div class="col-md-12">
            <div class="box">
                <div class="box-body">
                    <div class="pull-left">
                        <a href="javascript:void(0);" id="update-projects" class="btn btn-default">Update Projects</a>
                        <a href="javascript:void(0);" class="btn btn-default">Phones</a>
                        <a href="javascript:void(0);" class="btn btn-default">Routes</a>
                        <a href="javascript:void(0);" class="btn btn-default">Messages</a>
                        <a href="javascript:void(0);" class="btn btn-default">Groups</a>
                        <a href="javascript:void(0);" class="btn btn-default">Contacts</a>
                        <a href="javascript:void(0);" class="btn btn-default">Services</a>
                    </div>                </div>
            </div>
        </div>
    </div>
<div class="row">
            <div class="col-md-12">
                <div class="box">
                    <div class="box-body">
                        <div id="simgate-grid"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>


<!-- Modal -->
<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Update Projects</h4>
            </div>
            <div class="modal-body">

                <div class="row">
                    <div class="col-md-12 text-center">
                        <img src="~/Content/kendo/2014.1.318/Uniform/loading-image.gif" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->







<script>
    $(document).ready(function () {
        $("#simgate-grid").kendoGrid({
            dataSource: {
                type: "json",
                transport: {
                    read: {
                        async: true,
                        url: "@Html.Raw(Url.Action("Projects", "SimGate"))",
                        type: "POST",
                        dataType: "json",
                        data: additionalData
                    }
                },
                schema: {
                    data: "Data",
                    total: "Total",
                    errors: "Errors"
                },
                error: function(e) {
                    display_kendoui_grid_error(e);
                    // Cancel the changes
                    this.cancelChanges();
                },
                pageSize: @(gridPageSize),
                serverPaging: true,
                serverFiltering: true,
                serverSorting: true
            },
            pageable: {
                refresh: true
            },
            editable: {
                confirmation: false,
                mode: "inline"
            },
            scrollable: false,
            columnMenu: false,
            columns: [{
                field: "Name",
                title: "@T("Name")"
            }, {
                field: "TimeZone",
                title: "@T("Time zone")"
            }, {
                field: "Contacts",
                title: "@T("Contacts")"
            }, {
                field: "Phones",
                title: "@T("Phones")"
            }, {
                field: "Messages",
                title: "@T("Messages")"
            }, {
                field: "Routes",
                title: "@T("Routes")"
            }, {
                field: "Receipts",
                title: "@T("Receipts")"
            }, {
                field: "Active",
                title: "@T("Active")"
            }, {
                field: "UserID",
                title: "@T("UserID")"
            }, {
                field: "Id",
                title: "@T("Admin.Common.Edit")",
                width: 50,
        template: '<a href="Edit/#=Id#">@T("Admin.Common.Edit")</a>'
    }]
        });
    });
</script>
<script type="text/javascript">
$(document).ready(function() {
    $('#change-project').click(function() {
        var grid = $('#simgate-grid').data('kendoGrid');
        grid.dataSource.page(1);
        return false;
    });

    $('#SearchProjectId').on('change', function() {
        var grid = $('#simgate-grid').data('kendoGrid');
        grid.dataSource.page(1);
    });





    $('#update-projects').click(function() {

        $('#myModal').modal(
            {
                backdrop :'static',
                keyboard :false,

                
            });


        $.ajax({
            type: "POST",
            url: '@Url.Action("UpdateProjects", "SimGate")',
            data: additionalData(),
            dataType: "json",
            success: function (msg) {
                $('#myModal').modal('toggle');
                var grid = $('#simgate-grid').data('kendoGrid');
                grid.dataSource.page(1);

            }
        });







        return false;
    });






});

function additionalData() {
    var data = {
        SearchProjectId: $('#SearchProjectId').val(),
        CurrentProjectName: $("#SearchProjectId option:selected").text()
    };
    addAntiForgeryToken(data);
    return data;
}
</script>
