@using Nop.Web.Models.SimGate
@using Nop.Web.Framework.Kendoui;

@model DataSourceResult

@{


    Layout = "~/Views/Shared/_ColumnsOne.cshtml";
    var gridPageSize = 5;



}

@section Breadcrumb
{
    <span class="ribbon-button-alignment"><span class="btn btn-ribbon"><i class="fa-fw fa fa-user"></i></span></span>
    <ol class="breadcrumb">
        <li>@T("Account.MyAccount")</li>
        <li>@T("Account.CustomerAddresses.AddNew")</li>
    </ol>
}

    <div class="inbox-nav-bar no-content-padding">

        <h1 class="page-title txt-color-blueDark hidden-tablet">
            <i class="fa fa-fw fa-phone"></i> <strong>Phones &nbsp;</strong> 
        </h1>
        <div class="inbox-checkbox-triggered">
                <div class="btn-group hidden-desktop visible-tablet pull-left">
                    <button class="btn btn-default dropdown-toggle" data-toggle="dropdown">Phones<i class="fa fa-caret-down"></i></button>
                    <ul class="dropdown-menu pull-left">
                        <li><a href="@Url.Action("Phones", "SimGate")" class="inbox-load">Phones<i class="fa fa-check"></i></a></li>
                        @*<li><a href="@Url.Action("Routes", "SimGate")">Routes</a></li>*@
                    </ul>
                </div>

                <div class="btn-group pull-right">
                    <a href="javascript:void(0);" class="btn btn-default disabled"><strong><i class="fa fa-chevron-left"></i></strong></a>
                    <a href="javascript:void(0);" class="btn btn-default disabled"><span class="pull-right"><strong>1-@Model.Total</strong> of <strong>@Model.Total</strong></span></a>
                    <a href="javascript:void(0);" class="btn btn-default disabled"><strong><i class="fa fa-chevron-right"></i></strong></a>
                </div>
            </div>
    </div>

    <div id="inbox-content" class="inbox-body no-content-padding" style="min-height: 130px;">
        <div class="inbox-side-bar">
            <ul class="inbox-menu-lg">
                <li class="active"><a href="@Url.Action("Phones", "SimGate")">Phones</a></li>
                @*<li><a href="@Url.Action("Routes", "SimGate")">Routes</a></li>*@
            </ul>
            <div class="air air-bottom inbox-space">
                @Model.Total of <strong>5 Phones</strong>
                <div class="progress progress-micro">
                    <div class="progress-bar progress-primary" style="width: 60%;"></div>
                </div>
            </div>
        </div>
        <div style="opacity: 1;" class="table-wrap custom-scroll animated fast fadeInRight">
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="text-center">
                            <tr class="text-center">
                                <th class="text-center">Name</th>
                                <th class="text-center">Phone Number</th>
                                <th class="text-center">Last Active</th>
                                <th class="text-center">Battery</th>
                                <th class="text-center">Charging</th>
                                <th class="text-center">Mobile Network</th>
                                <th class="text-center">Connectivity</th>
                                <th class="text-center">App Version</th>
                                <th class="text-center">OS Version</th>
                                <th class="text-center">Manufacturer</th>
                                <th class="text-center">Model</th>

                            </tr>
                        </thead>
                        <tbody>

@foreach (PhoneModel item in Model.Data)
{
    <tr class="text-center">
        <td><strong>@item.Name</strong></td>
        <td><strong>@item.PhoneNumber</strong></td>
        <td><strong>@item.LastActiveDateTime</strong></td>
        <td><div class='easy-pie-chart txt-color-darken easyPieChart' data-percent="@item.Battery" data-pie-size='45'><span class='percent percent-sign font-sm'>@item.Battery</span></div></td>
        <td><strong><i class="@string.Concat("fa fa-fw ", (item.Charging == true) ? " fa-check-circle" : "fa-circle")"></i></strong></td>
        <td><strong>@item.Mccmnc</strong></td>
        <td><strong>@item.InternetType</strong></td>
        <td><strong>@item.AppVersion</strong></td>
        <td><strong>@item.AndroidSdk</strong></td>
        <td><strong>@item.Manufacturer</strong></td>
        <td><strong>@item.Model</strong></td>
    </tr>
}

                        </tbody>
                    </table>

                </div>


            </div>
    </div>
@section PageScripts
{

}
