                        <div class="progress-bar progress-primary" style="width: 34%;"></div>
                    </div>
                </div>
            </div>

        <div style="opacity: 1;" class="table-wrap custom-scroll animated fast fadeInRight @string.Concat((supportRtl)?" k-rtl":"")">
            <div id="simgate-grid"></div>
        </div>
        
