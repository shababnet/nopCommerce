@model FooterModel
@using Nop.Core
@using Nop.Core.Domain.Tax
@using Nop.Core.Infrastructure
@using Nop.Web.Models.Common;
<div class="footer">
    <div class="container">
        <div class="row">
            <div class="title padding-5">
                <strong>@T("Footer.FollowUs")</strong>
            </div>
        </div>
            <div class="row">
                <ul class="list-inline text-center">
                    @if (!string.IsNullOrEmpty(Model.FacebookLink))
                    {
                        <li><a class="btn btn-primary btn-circle" href="@Model.FacebookLink" target="_blank"><i class="fa fa-facebook"></i></a></li>
                    }
                    @if (!string.IsNullOrEmpty(Model.TwitterLink))
                    {
                        <li><a  class="btn btn-info btn-circle" href="@Model.TwitterLink" target="_blank"><i class="fa fa-twitter"></i></a></li>
                    }
                    @if (Model.NewsEnabled)
                    {
                        <li><a  class="btn btn-info btn-circle" href="@Url.RouteUrl("NewsRSS", new {languageId = Model.WorkingLanguageId})"><i class="fa fa-rss"></i></a></li>
                    }
                    @if (!string.IsNullOrEmpty(Model.YoutubeLink))
                    {
                        <li><a class="btn btn-info btn-circle" href="@Model.YoutubeLink" target="_blank"><i class="fa fa-youtube"></i></a></li>
                    }
                    @if (!string.IsNullOrEmpty(Model.GooglePlusLink))
                    {
                        <li><a class="btn btn-info btn-circle" href="@Model.GooglePlusLink" target="_blank"><i class="fa fa-google-plus"></i></a></li>
                    }
                    <li>
                        <a href="javascript:void(0);" class="btn btn-warning btn-circle"><i class="fa fa-linkedin"></i></a>
                    </li>
                </ul>
            </div>
        </div>
    <div class="container">
        <div class="row text-center padding-5">
            <span class="footer-disclaimer">@T("Content.CopyrightNotice", DateTime.Now.Year, Model.StoreName)</span>
        </div>
    </div>
</div>