@model PasswordRecoveryModel
@using Nop.Web.Models.Customer;
@{
    Layout = "~/Views/Shared/_ExtrPags_ColumnsOne.cshtml";

    //title
    Html.AddTitleParts(T("PageTitle.PasswordRecovery").Text);
}
<div class="row">
    <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
        <div class="well no-padding">

@using (Html.BeginForm("PasswordRecovery", "Customer", FormMethod.Post, new { @id = "login-form", @class = "smart-form client-form" }))
{

            <header>
                <strong>@T("Account.PasswordRecovery")</strong>
            </header>


    @Html.AntiForgeryToken()

    <p class="tooltip">@T("Account.PasswordRecovery.Tooltip")</p>

            <fieldset>
                <section>
                    @Html.LabelFor(model => model.Email, new { }, ":")
                    <label class="input">
                        <i class="icon-append fa fa-envelope"></i>
                        @Html.TextBoxFor(model => model.Email, new { @class = "email", autofocus = "autofocus" })
                        @Html.ValidationMessageFor(model => model.Email)
                                        </label>
                </section>
            </fieldset>




            <footer>
                <input type="submit" name="send-email" class="btn btn-primary" value="@T("Account.PasswordRecovery.RecoverButton")" />
            </footer>

}
        </div>

        @if (!String.IsNullOrEmpty(Model.Result))
            {
            <div class="result">
                @Model.Result
            </div>
        }
        </div>
    </div>
